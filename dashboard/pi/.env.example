# Copy to .env and fill in real values.

# URL of the Node dashboard. From the Pi's perspective.
BASE_URL=http://192.168.23.12:3000

# Must match PI_API_TOKEN in the dashboard's .env.
API_TOKEN=

# --- Camera ---
# auto = try CSI (picamera2) first, fall back to USB (OpenCV)
# csi  = force CSI / Pi Camera Module ribbon (needs python3-picamera2)
# usb  = force USB webcam via OpenCV
CAMERA_KIND=auto

# Only used for usb. The index of /dev/video* to open.
CAMERA_INDEX=0

CAMERA_WIDTH=640
CAMERA_HEIGHT=480

# Where to keep cached photos + embeddings.
# CACHE_DIR=

# Stricter values mean fewer false positives but more "couldn't
# match" rejections. 0.50 is a sensible starting point; dlib's
# default is 0.6.
MATCH_THRESHOLD=0.50

# Face must be the dominant subject for this many seconds before we
# trust the match. Stops people getting clocked in by walking past.
MIN_HOLD_SEC=1.5

# After clocking someone in/out, refuse to do it again for this
# many seconds. Prevents double punches if they linger in frame.
COOLDOWN_SEC=60

# Re-fetch the photo manifest every N seconds.
SYNC_EVERY_SEC=300

# Downscale frames before face detection (faster on Pi 3 / Pi 4).
FRAME_SCALE=0.5

# Optional override for the hostname reported to the dashboard.
# PI_HOST=lobby-pi

LOG_LEVEL=INFO

# --- Live camera stream (MJPEG) ---
# Serves the camera feed (with face boxes drawn) so the kiosk page
# can show staff a live preview. LAN-open, no authentication.
STREAM_ENABLED=true
STREAM_PORT=8080

# --- Buzzer ---
# A passive piezo buzzer on a GPIO pin gives staff an audible cue:
# a rising chirp when they're recognised, a low double-buzz when a
# face is seen but not matched. Set BUZZER_ENABLED=false if no
# buzzer is wired up.
#   Wiring: buzzer signal -> GPIO 18 (physical pin 12)
#           buzzer ground -> GND     (physical pin 14)
BUZZER_ENABLED=true
BUZZER_PIN=18

# Minimum seconds between "not recognised" buzzes, so an unknown
# face held in frame doesn't buzz on every frame.
BUZZER_REJECT_COOLDOWN=4

# --- Camera schedule ---
# The dashboard can put the camera on a schedule (Settings ->
# Camera schedule) so it only runs at the start and end of the day.
# The scanner polls the dashboard every STATE_POLL_SEC seconds to
# learn whether it should be matching faces; outside the scheduled
# hours it pauses recognition. The video stream keeps running, so
# the kiosk preview still works the moment someone taps to wake it.
STATE_POLL_SEC=15
