<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/static/css/kiosk.css">
</head>
<body class="kiosk">
<header class="kiosk-head">
    <div class="brand">
        <img src="/static/img/jondo-logo.png" alt="Jondo" class="brand-logo">
        <span class="brand-text">Time Clock</span>
    </div>
</header>
<main class="kiosk-main centered">
    <div class="pw-card">
        <h1>Sign in</h1>
        <p class="hint">Enter your time-clock username and password to clock in/out.</p>
        <% if (flash) { %><div class="kiosk-flash err"><%= flash %></div><% } %>
        <form method="post" action="/password" autocomplete="off">
            <label>Username
                <input type="text" name="username" required autofocus>
            </label>
            <label>Password
                <input type="password" name="password" required>
            </label>
            <label>Note (optional)
                <input type="text" name="notes" maxlength="240" placeholder="e.g. appointment, sick">
            </label>
            <button type="submit" class="kiosk-btn">Submit</button>
        </form>
        <p class="hint"><a href="/">&larr; Back to badge scan</a></p>
    </div>
</main>
</body>
</html>
