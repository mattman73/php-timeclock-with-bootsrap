<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/static/css/kiosk.css">
</head>
<body class="kiosk">
<header class="kiosk-head">
    <div class="brand">
        <img src="/static/img/jondo-logo.png" alt="Jondo" class="brand-logo">
        <span class="brand-text">Time Clock</span>
    </div>
</header>
<main class="kiosk-main centered">
    <div class="pw-card">
        <h1>Book time off</h1>
        <% if (flash) { %><div class="kiosk-flash err"><%= flash %></div><% } %>
        <% if (mode === 'password') { %>
            <p class="hint">Sign in with your time-clock username and password.</p>
            <form method="post" action="/book/start" autocomplete="off">
                <input type="hidden" name="mode" value="password">
                <label>Username
                    <input type="text" name="username" required autofocus autocomplete="off">
                </label>
                <label>Password
                    <input type="password" name="password" required>
                </label>
                <button type="submit" class="kiosk-btn">Continue</button>
            </form>
            <p class="hint"><a href="/book">Use my badge instead</a></p>
        <% } else { %>
            <p class="hint">Scan or type your badge number to start.</p>
            <form method="post" action="/book/start" autocomplete="off">
                <input type="hidden" name="mode" value="badge">
                <label>Badge number
                    <input type="text" name="BadgeID" inputmode="numeric"
                           required autofocus autocomplete="off">
                </label>
                <button type="submit" class="kiosk-btn">Continue</button>
            </form>
            <p class="hint"><a href="/book?mode=password">No badge? Sign in with username &amp; password</a></p>
        <% } %>
        <p class="hint"><a href="/">&larr; Back to clock in</a></p>
    </div>
</main>
</body>
</html>
