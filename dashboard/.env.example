# Copy this file to `.env` and fill in real values.

# --- HTTP server ---
PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string

# --- MySQL (same database the PHP timeclock uses) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=timeclock
DB_PASS=Fred1234
DB_NAME=timeclock
DB_PREFIX=

# --- Alert engine ---
# How often the late-arrival check runs (cron syntax). Default = every minute.
ALERT_CRON=* * * * *
# Timezone used for shift/clock-in comparisons (IANA name).
TZ=Europe/London

# --- Pi face-recognition scanner ---
# Shared secret used by the Raspberry Pi to authenticate to /api/*.
# Leave blank to disable the API entirely.
# Generate one with: openssl rand -hex 32
PI_API_TOKEN=
